# Copy to ".env" and fill in. Never commit the real .env.

# ---- Supabase ----
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# SERVER ONLY — never prefix with VITE_, never expose to the client.
SUPABASE_SECRET_KEY=sb_secret_...

# ---- Hosted web app URL ----
# Where the native (iOS/Android) apps send users to pay for Premium, so the
# purchase happens on the web and bypasses Apple/Google in-app-purchase fees.
# Set this to your real deployed domain at build time.
VITE_PUBLIC_WEB_URL=https://app.franschhoeklocal.co.za

# ---- Assistant backend (Claude) ----
# Also powers the content scraper's extraction fallback.
ANTHROPIC_API_KEY=sk-ant-...
# Optional: override the assistant API port (defaults to 8787)
# PORT=8787

# ---- Content scraper (npm run scrape) ----
# Writes scraped venues/events/deals using SUPABASE_SECRET_KEY (service role) and
# ANTHROPIC_API_KEY. For the every-4-hours GitHub Action, set these as repo secrets:
#   SUPABASE_URL, SUPABASE_SECRET_KEY, ANTHROPIC_API_KEY
# Optional: override the extraction model (defaults to Claude Haiku 4.5).
# SCRAPER_MODEL=claude-haiku-4-5-20251001

# ---- Yoco (payments) ----
# These are NOT used by this local .env — set them as Supabase Edge Function
# secrets so they stay server-side:
#   supabase secrets set YOCO_SECRET_KEY=sk_live_or_test_...
#   supabase secrets set YOCO_WEBHOOK_SECRET=whsec_...
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...   (for the "ask" function)
